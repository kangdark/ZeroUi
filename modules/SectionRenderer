local Theme =
    require(script.Parent.Theme)

local SectionRenderer = {}

function SectionRenderer:Create(
    Parent,
    Name
)

    local Label =
        Instance.new("TextLabel")

    Label.Parent = Parent

    Label.Size =
        UDim2.new(1,-10,0,25)

    Label.BackgroundTransparency = 1

    Label.Text = Name

    Label.TextColor3 =
        Theme.ToggleOn

    Label.TextXAlignment =
        Enum.TextXAlignment.Left

    return Label

end

return SectionRenderer
